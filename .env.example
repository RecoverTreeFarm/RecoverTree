# Copy this file to .env.local and fill in your own values.
# Find both values in the Supabase dashboard:
#   Project Settings -> API  (URL, and the "publishable" / anon key)
#
# NEVER put a secret key (sb_secret_... / service_role) in a NEXT_PUBLIC_ var.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
